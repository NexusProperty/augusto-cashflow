{
  "name": "augusto-cashflow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:acceptance": "vitest run tests/acceptance",
    "test:all": "npm run test:unit && npm run test:integration",
    "test:perf": "vitest run tests/performance",
    "test:e2e": "playwright test",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "gen:types": "supabase gen types typescript --local > lib/database.types.ts",
    "gen:types:remote": "supabase gen types typescript --linked > lib/database.types.ts",
    "update": "npm install && npm run db:push && npm run gen:types:remote && npm run typecheck",
    "prepare": "husky"
  },
  "dependencies": {
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.47.10",
    "clsx": "^2.1.1",
    "csv-parse": "^5.6.0",
    "exceljs": "^4.4.0",
    "mammoth": "^1.8.0",
    "next": "^15.2.0",
    "pdf-parse": "^1.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.3",
    "eslint-config-next": "^15.2.0",
    "husky": "^9.1.7",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  }
}
